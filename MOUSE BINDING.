#THIS IS THE METHOD NO2):-

import cv2
import numpy as np

def mouse_event(event, x, y, flags, param):
    print("event==", event)
    print("x==", x)
    print("y==", y)
    print("flags", flags)
    print("param", param)

    font = cv2.FONT_HERSHEY_PLAIN

    if event == cv2.EVENT_LBUTTONDOWN:
        cord = ". " + str(x) + ' , ' + str(y)
        cv2.putText(img, cord, (x, y), font, 1, (155, 125, 100), 2)
        cv2.imshow("res", img)

    if event == cv2.EVENT_RBUTTONDOWN:
        b = img[y, x, 0]
        g = img[y, x, 1]
        r = img[y, x, 2]
        color_bgr = ". " + str(b) + ' , ' + str(g) + ' , ' + str(r)
        cv2.putText(img, color_bgr, (x, y), font, 1, (152, 255, 130), 2)
        cv2.imshow("res", img)

cv2.namedWindow("res")
img = cv2.imread(r"A:\computer_Vision\54.jpg")
img = cv2.resize(img, (500, 500))
cv2.setMouseCallback("res", mouse_event)

while True:
    cv2.imshow("res", img)
    if cv2.waitKey(1) & 0xFF == 110:
        break

cv2.destroyAllWindows()
