#DRAWING ON THE IMAGE):-

import numpy as np
import cv2

img = cv2.imread(r"A:\computer_Vision\423.jpg")
img = cv2.resize(img, (500, 500))

# for balck screen
# img = np.zeros([512, 512, 3], np.uint8)*255#for black screen.

# for white screen
# img = np.ones([512, 512, 3], np.uint8)*255 #for white screen

# Draw line
img = cv2.line(img, (0, 0), (100, 200), (219, 174, 0), 1)

# Draw rectangle
img = cv2.rectangle(img, (100, 10), (384, 400), (219, 174, 0), 2)

#draw arrowed line
img = cv2.arrowedLine(img, (0, 0), (100, 200), (219, 174, 0), 4)

# Draw circle
img = cv2.circle(img, (447, 125), 60, (219, 174, 0), 3)

# Put text
font = cv2.FONT_HERSHEY_TRIPLEX
img = cv2.putText(img, 'M.ISMAEEL.KHAN', (20, 480), font, 1, (255, 0, 249), 2, cv2.LINE_AA)

# Draw ellipse
img = cv2.ellipse(img, (200, 200), (150, 200), 0, 200, 660, (219, 174, 0), 2)

cv2.imshow("res", img)
cv2.waitKey(0)
cv2.destroyAllWindows()
